{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "CI",
    "DATABASE_URL",
    "PAYLOAD_SECRET",
    "PAYLOAD_USER_EMAIL",
    "PAYLOAD_USER_PASSWORD"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "web#dev": {
      "dependsOn": ["web-db#start"],
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false
    },
    "format": {}
  }
}
